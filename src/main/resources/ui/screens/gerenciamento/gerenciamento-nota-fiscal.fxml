<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Button?>
<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="1003.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.fatecgru.controller.gerenciamento.GerenciamentoNotaFiscalController">

    <padding>
        <Insets bottom="30.0" left="210.0" right="210.0" top="100.0" />
    </padding>

    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #5a1a1a;" text="Gerenciamento de Nota Fiscal">
        <VBox.margin>
            <Insets bottom="20.0" />
        </VBox.margin>
    </Label>

    <VBox maxWidth="400.0" spacing="15.0">

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold;" text="Código" />
            <TextField fx:id="codigoField" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold;" text="Descrição" />
            <TextArea fx:id="descricaoArea" prefHeight="70.0" promptText="Descreva os materiais e valores individuais." wrapText="true" />
        </VBox>

        <HBox alignment="CENTER_LEFT" prefWidth="800.0" spacing="100.0">
            <VBox spacing="5.0">
                <Label style="-fx-font-weight: bold;" text="Data de Aquisição" />
                <DatePicker fx:id="dataAquisicaoField" promptText="Selecione a Data" />
            </VBox>

            <VBox fx:id="boxValor" spacing="5.0" prefWidth="130">
                <Label style="-fx-font-weight: bold;" text="Valor Total" />
                <TextField fx:id="valorField" prefWidth="60.0"/>
            </VBox>
        </HBox>

        <HBox alignment="CENTER_RIGHT" prefWidth="580.0" spacing="10.0">
            <Button onAction="#onExcluirClick" style="-fx-background-color: #b70c0c; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20 10 20; -fx-cursor: hand;" text="Excluir" />
            <Button onAction="#onSalvarClick" style="-fx-background-color: #1a1a57; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20 10 20; -fx-cursor: hand;" text="Salvar Alterações" />
        </HBox>

    </VBox>

</VBox>
