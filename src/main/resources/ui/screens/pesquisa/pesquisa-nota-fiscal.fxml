<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.control.cell.PropertyValueFactory?>
<VBox alignment="TOP_CENTER" spacing="20.0" prefHeight="700.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.edu.fatecgru.controller.pesquisa.PesquisaNotaFiscalController">

    <padding>
        <Insets top="30.0" left="100.0" right="100.0" bottom="50.0" />
    </padding>


    <Label text="Pesquisa de Nota Fiscal" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #5a1a1a;">
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </Label>

    <HBox spacing="20.0" alignment="CENTER" prefWidth="720.0">
        <TextField fx:id="searchField"  promptText="Digite aqui sua busca" prefWidth="500.0" prefHeight="35.0" />
        <Button text="Buscar" onAction="#onSearchClick" style="-fx-background-color: #1a1a57; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20 8 20; -fx-cursor: hand;" />
    </HBox>

    <TableView fx:id="resultsTable" onMouseClicked="#handleRowClick" VBox.vgrow="ALWAYS" prefHeight="400.0">
        <columns>
            <TableColumn text="Código" prefWidth="60.0">
                <cellValueFactory>
                    <PropertyValueFactory property="codigo" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn text="Descrição" prefWidth="300.0">
                <cellValueFactory>
                    <PropertyValueFactory property="descricao" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn text="Data de Aquisição" prefWidth="300.0">
                <cellValueFactory>
                    <PropertyValueFactory property="dataAquisicao" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn text="Valor" prefWidth="180.0" style="-fx-alignment: CENTER;">
                <cellValueFactory>
                    <PropertyValueFactory property="valor" />
                </cellValueFactory>
            </TableColumn>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>


</VBox>