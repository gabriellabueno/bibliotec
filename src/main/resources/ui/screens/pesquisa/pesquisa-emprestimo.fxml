<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<?import javafx.collections.FXCollections?>
<?import br.edu.fatecgru.model.Entity.*?>
<VBox alignment="TOP_CENTER" spacing="20.0" prefHeight="700.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.edu.fatecgru.controller.pesquisa.PesquisaEmprestimoController">

    <padding>
        <Insets top="30.0" left="100.0" right="100.0" bottom="50.0" />
    </padding>

    <Label text="Pesquisa de Empréstimo" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #5a1a1a;">
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </Label>

    <HBox spacing="30.0" alignment="CENTER">
        <RadioButton fx:id="rbAtivos" text="Ativos" selected="true" onAction="#handleRadioChange">
            <toggleGroup>
                <ToggleGroup fx:id="statusTypeGroup"/>
            </toggleGroup>
        </RadioButton>
        <RadioButton fx:id="rbAtrasados" text="Atrasados" toggleGroup="$statusTypeGroup" onAction="#handleRadioChange"/>
        <RadioButton fx:id="rbDevolvidos" text="Devolvidos" toggleGroup="$statusTypeGroup"
                     onAction="#handleRadioChange"/>
        <RadioButton fx:id="rbCancelados" text="Cancelados" toggleGroup="$statusTypeGroup"
                     onAction="#handleRadioChange"/>
    </HBox>

    <Separator />

    <HBox spacing="20.0" alignment="CENTER" prefWidth="720.0">
        <TextField fx:id="searchField"  promptText="Digite aqui sua busca" prefWidth="500.0" prefHeight="35.0" />
        <Button text="Buscar" onAction="#onSearchClick" style="-fx-background-color: #1a1a57; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20 8 20; -fx-cursor: hand;" />
    </HBox>

    <TableView fx:id="resultsTable" onMouseClicked="#handleRowClick" VBox.vgrow="ALWAYS" prefHeight="400.0" prefWidth="500.0">
        <columns>
            <TableColumn fx:id="colEmprestimoID" prefWidth="90.0" text="ID Empréstimo">
                <cellValueFactory><PropertyValueFactory property="idEmprestimo" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colMaterialIDEmprestimo" prefWidth="80.0" text="Código do Material">
                <cellValueFactory><PropertyValueFactory property="idMaterial" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colTituloMaterial" prefWidth="120.0" text="Material">
                <cellValueFactory><PropertyValueFactory property="tituloMaterial" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colUsuarioIDEmprestimo" prefWidth="80.0" text="ID do Usuário">
                <cellValueFactory><PropertyValueFactory property="idUsuario" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colNomeUsuario" prefWidth="120.0" text="Usuário">
                <cellValueFactory><PropertyValueFactory property="nomeUsuario" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colDataEmprestimo" prefWidth="150.0" text="Data do Empréstimo">
                <cellValueFactory><PropertyValueFactory property="dataEmprestimo" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colDataPrevista" prefWidth="600.0" text="Data Prevista de Devolução">
                <cellValueFactory><PropertyValueFactory property="dataPrevistaDevolucao" /></cellValueFactory>
            </TableColumn>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>

    </TableView>



</VBox>